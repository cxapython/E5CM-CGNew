            return False
        try:
            预览 = pygame.Surface((max(1, rect.w), max(1, rect.h))).convert()
            预览.fill((0, 0, 0))
            self._绘制contain预览面(预览, 视频帧)
            屏幕.blit(预览, rect.topleft)
            return True
        except Exception:
