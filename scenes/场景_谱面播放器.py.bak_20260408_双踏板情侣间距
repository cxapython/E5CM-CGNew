def _标准化谱面候选文本(文本: str) -> str:
    结果 = str(文本 or "").strip().lower()
    结果 = re.sub(r"[\s_\-]+", "", 结果)
    return str(结果)


def _谱面候选命中标识(候选: Dict[str, str], 标识: str) -> bool:
    目标 = _标准化谱面候选文本(标识)
    if not 目标:
        return False
    charttype = _标准化谱面候选文本(str(候选.get("charttype", "") or ""))
    description = _标准化谱面候选文本(str(候选.get("description_text", "") or ""))
    difficulty = _标准化谱面候选文本(str(候选.get("difficulty_text", "") or ""))
    目标文本 = str(目标)
    if charttype == 目标文本 or 目标文本 in charttype:
        return True
    if 目标文本 in description or 目标文本 in difficulty:
        return True
    return False


def _收集sm谱面候选信息(sm文本: str) -> List[Dict[str, str]]:
    候选列表: List[Dict[str, str]] = []

    for m in re.finditer(r"#NOTES\s*:(.*?);", sm文本, flags=re.IGNORECASE | re.DOTALL):
        字段 = _解析_sm_notes块字段(m.group(1))
        if not isinstance(字段, dict):
            continue
        notedata = str(字段.get("notes_text", "") or "")
        候选列表.append(
            {
                "charttype": str(字段.get("charttype", "") or ""),
                "description_text": str(字段.get("description_text", "") or ""),
                "difficulty_text": str(字段.get("difficulty_text", "") or ""),
                "notes_text": notedata,
                "meter_text": str(字段.get("meter_text", "") or ""),
                "bpms_text": "",
                "offset_text": "",
                "columns": str(_计算谱面列数(notedata)),
                "format": str(字段.get("format", "") or "sm"),
            }
        )

    for 块文本 in _提取ssc谱面块列表(sm文本):
        charttype = _提取sm标签值(块文本, "STEPSTYPE").lower()
        notedata = _提取sm标签原始值(块文本, "NOTES")
        if not notedata:
            continue
        候选列表.append(
            {
                "charttype": str(charttype or ""),
                "description_text": str(_提取sm标签值(块文本, "DESCRIPTION") or ""),
                "difficulty_text": str(_提取sm标签值(块文本, "DIFFICULTY") or ""),
                "notes_text": str(notedata or ""),
                "meter_text": str(_提取sm标签值(块文本, "METER") or ""),
                "bpms_text": str(_提取sm标签值(块文本, "BPMS") or ""),
                "offset_text": str(_提取sm标签值(块文本, "OFFSET") or ""),
                "columns": str(_计算谱面列数(notedata)),
                "format": "ssc",
            }
        )

    return 候选列表


def _解析_sm_notes_选谱面(
    sm文本: str,
    优先double: bool = False,
    目标charttype: str = "",
    目标关键词: str = "",
    严格匹配目标: bool = False,
) -> Tuple[str, int, str, str, str]:
    """
    选中一个谱面块返回 (notedata, 列数, charttype, 局部BPMS文本, 局部OFFSET文本)
    默认优先 pump-single；当 优先double=True 时优先 pump-double。
    """
    候选 = _收集sm谱面候选信息(sm文本)

    if not 候选:
        return "", 5, "", "", ""

    关键词 = str(目标关键词 or "").strip().lower()
    if 关键词:
        关键词候选 = [
            项 for 项 in 候选 if _谱面候选命中标识(dict(项), str(关键词))
        ]
        if 关键词候选:
            候选 = 关键词候选
        elif bool(严格匹配目标):
            return "", 5, "", "", ""

    指定类型 = str(目标charttype or "").strip().lower()
    if 指定类型:
        指定候选 = [
            项
            for 项 in 候选
            if _谱面候选命中标识(dict(项), str(指定类型))
        ]
        if 指定候选:
            候选 = 指定候选
        elif bool(严格匹配目标):
            return "", 5, "", "", ""

    选中chart = max(
        候选,
        key=lambda 项: _谱面候选优先级(
            str(项.get("charttype", "") or ""),
            int(项.get("columns", 0) or 0),
            str(项.get("meter_text", "") or ""),
            优先double=bool(优先double),
        ),
    )

    纯 = str(选中chart.get("notes_text", "") or "").replace("\r", "")
    列数 = int(max(1, int(选中chart.get("columns", 5) or 5)))
    return (
        纯,
        列数,
        str(选中chart.get("charttype", "") or ""),
        str(选中chart.get("bpms_text", "") or ""),
        str(选中chart.get("offset_text", "") or ""),
    )


def _构建_sm事件列表(
    sm路径: str,
    优先double: bool = False,
    目标charttype: str = "",
    目标关键词: str = "",
    严格匹配目标: bool = False,
) -> Tuple[
    List[音符事件],
    List[手键装饰事件],
    float,
    float,
    int,
    str,
    List[Tuple[float, float]],
]:
    """
    返回：(主事件列表, 手键装饰事件列表, offset, 总时长秒, 列数, charttype, bpms_beat)

    ✅ 关键修复：事件时间轴直接应用 SM OFFSET
    - SM 里通常是：note_song_time = beat_to_seconds(beat) - offset
    - 所以我们把 offset 折算进事件秒，后续“谱面秒 == 音频秒”最稳

    ✅ 时间轴按 BPMS 走
    """
    sm文本 = _安全读文本(sm路径)
    if not sm文本:
        return [], [], 0.0, 0.0, 5, "", [(0.0, 120.0)]

    offset = _解析_offset(sm文本)
    bpms = _解析_bpms(sm文本)
    (
        notedata,
        列数,
        charttype,
        局部bpms文本,
        局部offset文本,
    ) = _解析_sm_notes_选谱面(
        sm文本,
        优先double=bool(优先double),
        目标charttype=str(目标charttype or ""),
        目标关键词=str(目标关键词 or ""),
        严格匹配目标=bool(严格匹配目标),
    )
    if not notedata:
        return [], [], offset, 0.0, 5, "", list(bpms or [(0.0, 120.0)])

    if 局部offset文本:
        try:
            offset = float(str(局部offset文本).strip())
        except Exception:
            pass

    if 局部bpms文本:
        局部bpms = _解析_bpms原始值(
            局部bpms文本, 行每拍=_解析_rowsperbeat(sm文本)
        )
        if 局部bpms:
            bpms = 局部bpms

    bpm段 = _生成时间轴段(bpms)

    小节列表 = [m.strip() for m in notedata.split(",")]
    事件: List[音符事件] = []

    if _是否舞推专用sm候选(charttype, 列数):
        手键方向映射 = dict(_读取手键aType映射配置() or _舞推手槽位默认方向)
        每组宽 = int(_舞推每组槽位数)
        总组数 = max(1, int(列数) // 每组宽)
        活跃主轨组: List[int] = []
        活跃任意组: List[int] = []
        for 小节 in 小节列表:
            行们 = [
                ln.strip()
                for ln in 小节.split("\n")
                if ln.strip() and (not ln.strip().startswith("//"))
            ]
            for 行 in 行们:
                if len(行) < 列数:
                    continue
                for 组序号 in range(总组数):
                    起 = int(组序号) * 每组宽
                    组文本 = 行[起 : 起 + 每组宽]
                    if not str(组文本 or "").strip("0"):
                        continue
                    if int(组序号) not in 活跃任意组:
                        活跃任意组.append(int(组序号))
                    if any(
                        (槽位 < len(组文本)) and (组文本[槽位] != "0")
                        for 槽位 in _舞推脚槽位到轨道.keys()
                    ) and int(组序号) not in 活跃主轨组:
                        活跃主轨组.append(int(组序号))

        if not 活跃主轨组:
            活跃主轨组 = list(活跃任意组 or [0])

        if len(活跃主轨组) >= 2:
            归一分组列表 = list(活跃主轨组[:2])
        else:
            归一分组列表 = list(活跃主轨组[:1] or [0])
        归一分组映射 = {int(组): 索引 for 索引, 组 in enumerate(归一分组列表)}

        事件: List[音符事件] = []
        手键事件: List[手键装饰事件] = []
        未闭合主轨: Dict[Tuple[int, int], Tuple[float, float]] = {}
        未闭合手键: Dict[Tuple[int, str], Tuple[float, float]] = {}
        最大秒 = 0.0

        for 小节序号, 小节 in enumerate(小节列表):
            行们 = [
                ln.strip()
                for ln in 小节.split("\n")
                if ln.strip() and (not ln.strip().startswith("//"))
            ]
            if not 行们:
                continue

            分割数 = len(行们)
            for 行序号, 行 in enumerate(行们):
                if len(行) < 列数:
                    continue

                beat = float(小节序号) * 4.0 + (float(行序号) / float(max(1, 分割数))) * 4.0
                t = _beat转秒(beat, bpm段) - float(offset)

                for 组序号 in range(总组数):
                    起 = int(组序号) * 每组宽
                    组文本 = 行[起 : 起 + 每组宽]
                    if len(组文本) < 每组宽:
                        continue

                    归一玩家索引 = 归一分组映射.get(int(组序号))
                    for 槽位, ch in enumerate(组文本):
                        if ch == "0":
                            continue

                        if 槽位 in _舞推脚槽位到轨道:
                            if 归一玩家索引 is None:
                                continue
                            轨道 = int(归一玩家索引) * 5 + int(_舞推脚槽位到轨道[槽位])
                            键 = (int(归一玩家索引), int(轨道))
                            if ch == "1":
                                事件.append(
                                    音符事件(
                                        轨道序号=int(轨道),
                                        开始秒=float(t),
                                        结束秒=float(t),
                                        开始beat=float(beat),
                                        结束beat=float(beat),
                                        类型="tap",
                                    )
                                )
                                最大秒 = max(最大秒, float(t))
                                continue
                            if ch in ("2", "4"):
                                未闭合主轨[键] = (float(t), float(beat))
                                最大秒 = max(最大秒, float(t))
                                continue
                            if ch == "3":
                                if 键 not in 未闭合主轨:
                                    continue
                                st秒, stbeat = 未闭合主轨.pop(键)
                                ed秒 = float(t)
                                edbeat = float(beat)
                                if ed秒 < st秒:
                                    st秒, ed秒 = ed秒, st秒
                                    stbeat, edbeat = edbeat, stbeat
                                事件.append(
                                    音符事件(
                                        轨道序号=int(轨道),
                                        开始秒=float(st秒),
                                        结束秒=float(ed秒),
                                        开始beat=float(stbeat),
                                        结束beat=float(edbeat),
                                        类型="hold",
                                    )
                                )
                                最大秒 = max(最大秒, float(ed秒))
                            continue

                        方向 = str(手键方向映射.get(int(槽位), "") or "")
                        if not 方向:
                            continue

                        if 归一玩家索引 is None:
                            if len(归一分组映射) == 1:
                                归一玩家索引 = 0
                            else:
                                continue
                        玩家序号 = int(归一玩家索引) + 1
                        手键 = (int(归一玩家索引), str(方向))
                        if ch == "1":
                            手键事件.append(
                                手键装饰事件(
                                    方向=方向,
                                    开始秒=float(t),
                                    结束秒=float(t),
                                    开始beat=float(beat),
                                    结束beat=float(beat),
                                    类型="tap",
                                    玩家=int(玩家序号),
                                    是否已触发自动特效=False,
                                )
                            )
                            最大秒 = max(最大秒, float(t))
                            continue
                        if ch in ("2", "4"):
                            未闭合手键[手键] = (float(t), float(beat))
                            最大秒 = max(最大秒, float(t))
                            continue
                        if ch == "3":
                            if 手键 not in 未闭合手键:
                                continue
                            st秒, stbeat = 未闭合手键.pop(手键)
                            ed秒 = float(t)
                            edbeat = float(beat)
                            if ed秒 < st秒:
                                st秒, ed秒 = ed秒, st秒
                                stbeat, edbeat = edbeat, stbeat
                            手键事件.append(
                                手键装饰事件(
                                    方向=方向,
                                    开始秒=float(st秒),
                                    结束秒=float(ed秒),
                                    开始beat=float(stbeat),
                                    结束beat=float(edbeat),
                                    类型="hold",
                                    玩家=int(玩家序号),
                                    是否已触发自动特效=False,
                                )
                            )
                            最大秒 = max(最大秒, float(ed秒))

        事件.sort(key=lambda e: e.开始秒)
        手键事件.sort(key=lambda e: e.开始秒)
        结果列数 = 10 if len(归一分组映射) >= 2 else 5
        结果chart类型 = "pump-double" if int(结果列数) >= 10 else "pump-single"
        总时长 = max(0.0, 最大秒 + 2.0)
        return (
            事件,
            手键事件,
            float(offset),
            float(总时长),
            int(结果列数),
            str(结果chart类型),
            list(bpms or [(0.0, 120.0)]),
        )

    未闭合: Dict[int, Tuple[float, float]] = {}  # 轨道 -> (开始秒, 开始beat)
    最大秒 = 0.0

    for 小节序号, 小节 in enumerate(小节列表):
        行们 = [
            ln.strip()
            for ln in 小节.split("\n")
            if ln.strip() and (not ln.strip().startswith("//"))
        ]
        if not 行们:
            continue

        分割数 = len(行们)

        for 行序号, 行 in enumerate(行们):
            if len(行) < 列数:
                continue

            beat = float(小节序号) * 4.0 + (float(行序号) / float(max(1, 分割数))) * 4.0

            # ✅ 核心：把 offset 折算进事件秒
            t = _beat转秒(beat, bpm段) - float(offset)

            for 列 in range(列数):
                ch = 行[列]
                if ch == "0":
                    continue

                if ch == "1":
                    事件.append(
                        音符事件(
                            轨道序号=int(列),
                            开始秒=float(t),
                            结束秒=float(t),
                            开始beat=float(beat),
                            结束beat=float(beat),
                            类型="tap",
                        )
                    )
                    最大秒 = max(最大秒, float(t))
                    continue

                if ch in ("2", "4"):  # hold/roll 头
                    未闭合[int(列)] = (float(t), float(beat))
                    最大秒 = max(最大秒, float(t))
                    continue

                if ch == "3":  # hold 尾
                    if int(列) in 未闭合:
                        st秒, stbeat = 未闭合.pop(int(列))
                        ed秒 = float(t)
                        edbeat = float(beat)

                        if ed秒 < st秒:
                            st秒, ed秒 = ed秒, st秒
                            stbeat, edbeat = edbeat, stbeat

                        事件.append(
                            音符事件(
                                轨道序号=int(列),
                                开始秒=float(st秒),
                                结束秒=float(ed秒),
                                开始beat=float(stbeat),
                                结束beat=float(edbeat),
                                类型="hold",
                            )
                        )
                        最大秒 = max(最大秒, ed秒)
                    continue

                # 其他类型先忽略（M/K/L 等）

    事件.sort(key=lambda e: e.开始秒)
    总时长 = max(0.0, 最大秒 + 2.0)
    return (
        事件,
        [],
        float(offset),
        float(总时长),
        int(列数),
        str(charttype or ""),
        list(bpms or [(0.0, 120.0)]),
    )


def _构建_sm情侣事件列表(
    sm路径: str,
) -> Tuple[
    Optional[
        Tuple[
            List[音符事件],
            List[手键装饰事件],
            float,
            float,
            int,
            str,
            List[Tuple[float, float]],
        ]
    ],
    str,
]:
    sm文本 = _安全读文本(sm路径)
    if not sm文本:
        return None, "情侣谱面读取失败，已回退单谱模式"

    候选列表 = _收集sm谱面候选信息(sm文本)
    命中lover1 = any(
        _谱面候选命中标识(dict(项), "lover1")
        for 项 in 候选列表
        if isinstance(项, dict)
    )
    命中lover2 = any(
        _谱面候选命中标识(dict(项), "lover2")
        for 项 in 候选列表
        if isinstance(项, dict)
    )
    if (not 命中lover1) or (not 命中lover2):
        if (not 命中lover1) and (not 命中lover2):
            return None, "情侣谱面缺少 lover1 / lover2，已回退单谱模式"
        缺失标识 = "lover1" if (not 命中lover1) else "lover2"
        return None, f"情侣谱面缺少 {缺失标识}，已回退单谱模式"

    左结果 = _构建_sm事件列表(
        sm路径,
        优先double=False,
        目标关键词="lover1",
        严格匹配目标=True,
    )
    右结果 = _构建_sm事件列表(
        sm路径,
        优先double=False,
        目标关键词="lover2",
        严格匹配目标=True,
    )

    (
        左事件列表,
        左手键列表,
        左偏移,
        左总时长,
        _左列数,
        _左charttype,
        左bpms,
    ) = 左结果
    (
        右事件列表,
        右手键列表,
        右偏移,
        右总时长,
        _右列数,
        _右charttype,
        右bpms,
    ) = 右结果

    if (not 左事件列表 and not 左手键列表) or (not 右事件列表 and not 右手键列表):
        return None, "情侣谱面解析不完整，已回退单谱模式"

    合并事件: List[音符事件] = []
    for 事件项 in list(左事件列表 or []):
        try:
            轨道 = int(getattr(事件项, "轨道序号", -1))
        except Exception:
            轨道 = -1
        if 轨道 < 0:
            continue
        合并事件.append(replace(事件项, 轨道序号=int(轨道 % 5)))
    for 事件项 in list(右事件列表 or []):
        try:
            轨道 = int(getattr(事件项, "轨道序号", -1))
        except Exception:
            轨道 = -1
        if 轨道 < 0:
            continue
        合并事件.append(replace(事件项, 轨道序号=int((轨道 % 5) + 5)))
    合并事件.sort(key=lambda 事件项: float(getattr(事件项, "开始秒", 0.0) or 0.0))

    合并手键: List[手键装饰事件] = []
    for 事件项 in list(左手键列表 or []):
        try:
            合并手键.append(replace(事件项, 玩家=1))
        except Exception:
            continue
    for 事件项 in list(右手键列表 or []):
        try:
            合并手键.append(replace(事件项, 玩家=2))
        except Exception:
            continue
    合并手键.sort(key=lambda 事件项: float(getattr(事件项, "开始秒", 0.0) or 0.0))

    偏移 = float(左偏移)
    if abs(float(偏移)) <= 1e-6:
        偏移 = float(右偏移)
    总时长 = float(max(float(左总时长), float(右总时长)))
    bpms_beat = list(左bpms or 右bpms or [(0.0, 120.0)])

    return (
        (
            合并事件,
            合并手键,
            float(偏移),
            float(总时长),
            10,
            "lover-double",
            bpms_beat,
        ),
        "",
    )


def _读取手键aType映射配置() -> Dict[int, str]:
