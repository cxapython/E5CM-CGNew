            max(
                0.1,
                float(getattr(self, "_个人资料资源刷新间隔秒", 0.5) or 0.5),
            )
        )
        if (not 强制) and 当前系统秒 < float(
            getattr(self, "_个人资料资源下次刷新秒", 0.0) or 0.0
        ):
            return

        self._个人资料资源下次刷新秒 = float(当前系统秒 + 刷新间隔秒)
