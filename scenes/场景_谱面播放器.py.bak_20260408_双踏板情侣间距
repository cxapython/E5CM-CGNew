                基础优先级 = 55
            elif 谱面类型 in {"lover1", "lover2"}:
                基础优先级 = 40
            else:
                基础优先级 = 10
        恋爱优先 = 1 if 谱面类型 == "lover1" else 0
        return (基础优先级, meter, 总列数, 恋爱优先)

    if bool(优先double):
        if "pump-double" in 谱面类型:
            基础优先级 = 80
        elif "pump-single" in 谱面类型:
            基础优先级 = 70
        elif "dance-single" in 谱面类型:
            基础优先级 = 60
        elif "single" in 谱面类型:
