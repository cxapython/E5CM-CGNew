    def _绘制背景(self, 屏幕: pygame.Surface):
        w, h = 屏幕.get_size()
        已绘制背景 = False

        背景模式 = self._取背景渲染模式()
        准备动画激活 = bool(getattr(self, "_显示准备动画", False)) and (
            not bool(getattr(self, "_准备动画已完成", True))
        )
        背景现在秒 = float(time.perf_counter())
        当前背景源 = self._取当前背景源()
        背景图 = None
        准备动画动态背景图 = None
        动态背景准备图已刷新 = False
        if str(背景模式 or "图片") != "图片":
            self._停止背景转场()
        if 背景模式 == "动态背景" and bool(准备动画激活):
            动态背景准备图已刷新 = True
            try:
                准备动画动态背景图 = self._刷新准备动画动态背景截图(
                    (w, h), 背景现在秒
                )
            except Exception:
                准备动画动态背景图 = getattr(self, "_准备动画背景无蒙版", None)
        if isinstance(准备动画动态背景图, pygame.Surface):
            背景图 = 准备动画动态背景图
        elif 当前背景源 is not None and hasattr(当前背景源, "取CPU帧"):
            try:
                背景图 = 当前背景源.取CPU帧(self, 背景现在秒)
            except Exception:
                背景图 = None
        if isinstance(背景图, pygame.Surface):
            try:
                self._绘制cover背景面(屏幕, 背景图)
                已绘制背景 = True
            except Exception:
                已绘制背景 = False

        if (not 已绘制背景) and 背景模式 == "视频":
            try:
                视频帧 = self._读取背景视频帧()
                if isinstance(视频帧, pygame.Surface):
                    self._绘制cover背景面(屏幕, 视频帧)
                    已绘制背景 = True
            except Exception:
                已绘制背景 = False

        if not 已绘制背景:
            if 背景模式 == "动态背景" and bool(准备动画激活):
                self._停止背景转场()
                屏幕.fill((15, 15, 18))
                背景图 = None
            elif 背景模式 == "视频" and bool(self._准备动画视频背景禁止图片回退()):
                self._停止背景转场()
                屏幕.fill((15, 15, 18))
                背景图 = None
            else:
                背景图 = self._取背景图片帧(背景现在秒)
                if isinstance(背景图, pygame.Surface):
                    if not self._绘制背景图片转场(屏幕, 背景现在秒):
                        self._绘制cover背景面(屏幕, 背景图)
                else:
                    self._停止背景转场()
                    屏幕.fill((15, 15, 18))

        if bool(准备动画激活):
            if bool(self._准备动画处于动态预展示()):
                if not bool(动态背景准备图已刷新):
                    self._刷新准备动画动态背景截图((w, h), 背景现在秒)
            else:
                当前背景模式 = str(背景模式 or "图片")
                if 当前背景模式 == "动态背景":
                    if not bool(动态背景准备图已刷新):
                        self._刷新准备动画动态背景截图((w, h), 背景现在秒)
                elif 当前背景模式 == "视频":
                    需刷新视频快照 = False
                    try:
                        当前快照 = getattr(self, "_准备动画背景无蒙版", None)
                        当前快照类型 = str(
                            getattr(self, "_准备动画背景快照类型", "") or ""
                        )
                        if (
                            (not isinstance(当前快照, pygame.Surface))
                            or 当前快照.get_size() != (w, h)
                            or 当前快照类型 != "视频"
                        ):
                            需刷新视频快照 = True
                    except Exception:
                        需刷新视频快照 = True

                    if 需刷新视频快照:
                        self._刷新准备动画背景快照((w, h), time.perf_counter())
                elif bool(self._应使用GPU背景层()):
                    self._刷新准备动画背景快照((w, h), time.perf_counter())
                else:
                    需刷新无蒙版 = False
                    try:
                        if (
                            self._准备动画背景无蒙版 is None
                            or self._准备动画背景无蒙版.get_size() != (w, h)
                        ):
                            需刷新无蒙版 = True
                    except Exception:
                        需刷新无蒙版 = True

                    if 需刷新无蒙版:
                        try:
                            self._准备动画背景无蒙版 = 屏幕.copy()
                            self._准备动画背景快照类型 = "图片"
                        except Exception:
                            self._准备动画背景无蒙版 = None
                            self._准备动画背景快照类型 = ""
                        self._准备动画最近视频快照命中 = False

        try:
            遮罩alpha = int(self._取当前背景遮罩alpha())
            if 遮罩alpha > 0:
                if (
                    self._背景暗层缓存 is None
                    or self._背景暗层缓存.get_size() != (w, h)
                    or int(getattr(self, "_背景暗层缓存alpha", -1)) != 遮罩alpha
                ):
                    self._背景暗层缓存 = pygame.Surface((w, h), pygame.SRCALPHA)
                    self._背景暗层缓存.fill((0, 0, 0, int(遮罩alpha)))
                    self._背景暗层缓存alpha = int(遮罩alpha)
                屏幕.blit(self._背景暗层缓存, (0, 0))
        except Exception:
            pass

    @staticmethod
    def _秒格式化(t: float) -> str:
        t = float(max(0.0, t))
        m = int(t // 60)
        s = t - m * 60
        return f"{m:02d}:{s:05.2f}"

