                        结束秒=float(getattr(e, "结束秒", 0.0) or 0.0),
                        开始beat=float(getattr(e, "开始beat", 0.0) or 0.0),
                        结束beat=float(getattr(e, "结束beat", 0.0) or 0.0),
                        类型=str(getattr(e, "类型", "tap") or "tap"),
