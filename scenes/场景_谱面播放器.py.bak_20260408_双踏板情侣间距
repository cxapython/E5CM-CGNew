            return
        if not isinstance(getattr(self, "_判定统计", None), dict):
            self._判定统计 = {"perfect": 0, "cool": 0, "good": 0, "miss": 0}
        for 回报 in 回报列表:
            判定 = str(getattr(回报, "判定", "") or "").lower().strip()
            if 判定 in self._判定统计:
                try:
                    self._判定统计[判定] = int(self._判定统计.get(判定, 0) or 0) + 1
                except Exception:
                    self._判定统计[判定] = 1

