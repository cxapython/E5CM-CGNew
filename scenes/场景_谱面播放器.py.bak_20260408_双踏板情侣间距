            ):
                try:
                    锁定y = int(getattr(self, "_双踏板入场锁定判定线y"))
                    左判定线y = 锁定y
                    右判定线y = 锁定y
                except Exception:
                    pass

            if bool(双踏板模式):
                原事件列表_左 = getattr(self, "_事件左渲染", []) or []
                原手键列表_左 = getattr(self, "_手键装饰事件左渲染", []) or []
            else:
