                原手键列表_左 = getattr(self, "_手键装饰事件列表", []) or []
            事件列表_左 = (
                原事件列表_左
                if isinstance(原事件列表_左, list)
                else list(原事件列表_左)
            )
            手键列表_左 = (
                原手键列表_左
                if isinstance(原手键列表_左, list)
