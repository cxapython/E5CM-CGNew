    def _esc_menu_draw_video_preview(self, 屏幕: pygame.Surface, rect: pygame.Rect) -> bool:
        if not isinstance(屏幕, pygame.Surface) or (not isinstance(rect, pygame.Rect)):
            return False
        播放器 = self._取ESC菜单视频预览播放器()
