            新载荷 = dict(self._载荷)
            新载荷["操作反馈文本"] = "ESC菜单:歌曲重载成功"
            return {
                "切换到": "谱面播放器",
                "载荷": 新载荷,
                "禁用黑屏过渡": True,
            }
        if str(target) == "match":
            状态 = self.上下文.get("状态", {}) if isinstance(self.上下文, dict) else None
            return _执行共享返回选歌(状态, getattr(self, "_载荷", {}))
        if str(target) == "desktop":
