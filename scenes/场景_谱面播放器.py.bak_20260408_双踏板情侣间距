    def _绑定圆环频谱音频(self):
        对象 = getattr(self, "_圆环频谱舞台装饰", None)
        if 对象 is None:
            return False
        音频路径 = str(getattr(self, "_音频路径", "") or "").strip()
        if (not 音频路径) or (not os.path.isfile(音频路径)):
            return False
        self._初始化音频设备()
        if not bool(getattr(self, "_音频可用", False)):
            return False
        try:
            对象.绑定音频(str(音频路径))
            try:
                self._圆环频谱音频绑定失败原因 = ""
            except Exception:
                pass
            return True
        except Exception as 异常:
            # 圆环频谱只是装饰层；部分母包 mp3 可被 music.load 播放，
            # 但无法被 pygame.mixer.Sound 整首解码取样，此时静默降级为假频谱。
            try:
                对象._已载入样本 = False
                对象._上次幅度 = None
            except Exception:
                pass
            try:
                self._圆环频谱音频绑定失败原因 = (
                    f"{type(异常).__name__} {异常}"
                )
            except Exception:
                pass
            return False

