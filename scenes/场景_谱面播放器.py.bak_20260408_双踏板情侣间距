            左判定线y = int(self._取当前判定线y("左"))
            右判定线y = int(self._取当前判定线y("右"))
            if (
                bool(双踏板模式)
                and float(当前系统秒)
                <= float(getattr(self, "_双踏板入场Y锁定至秒", 0.0) or 0.0)
