        _读取手键aType映射配置._缓存路径 = ""
    if not isinstance(getattr(_读取手键aType映射配置, "_缓存mtime", None), float):
        _读取手键aType映射配置._缓存mtime = -2.0
    try:
        根目录 = os.path.abspath(_公共取运行根目录())
    except Exception:
