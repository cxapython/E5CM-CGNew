                getattr(self, "_双踏板强制判定线y", getattr(self, "_判定线y", 0) or 0)
            )
        except Exception:
            self._双踏板入场锁定判定线y = int(getattr(self, "_判定线y", 0) or 0)

        self._双踏板入场Y锁定至秒 = float(当前系统秒) + 0.55
