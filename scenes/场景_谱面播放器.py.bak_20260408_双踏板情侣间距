def _解析大小倍率(设置参数: dict, 参数文本: str) -> float:
    # 你说“大小=设置参数文本”，所以优先从 参数文本 取；取不到再用 dict
    文本值 = _从设置参数文本提取(参数文本, "大小")
    候选 = 文本值 if 文本值 else str(设置参数.get("大小", "") or "")
    候选 = str(候选).strip()

    if not 候选:
        return 1.0

    if "放大" in 候选:
        return 1.0
    if "正常" in 候选:
        return 0.8

    # 允许：1.2 / 120% / 0.95
    try:
        if 候选.endswith("%"):
            v = float(候选[:-1].strip()) / 100.0
            return max(0.5, min(2.0, v))
        v = float(候选)
        return max(0.5, min(2.0, v))
    except Exception:
        return 1.0


